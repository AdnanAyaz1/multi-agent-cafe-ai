# AI - Groq (get key at https://console.groq.com/keys)
GROQ_API_KEY=replace-me

# Default model for all agents
GROQ_MODEL=llama-3.1-8b-instant

# Optional: override model for ALL agents (ignores MODEL_* below)
# GROQ_MODEL_OVERRIDE=

# Optional: per-agent model overrides
# MODEL_MENU_ANALYST=llama-3.1-8b-instant
# MODEL_WEATHER_ANALYST=llama-3.1-8b-instant
# MODEL_STRATEGIST=llama-3.1-8b-instant
# MODEL_CRITIC=llama-3.1-8b-instant
# MODEL_SYNTHESIZER=llama-3.1-8b-instant
# MODEL_COMPETITOR_PARSER=llama-3.1-8b-instant
# MODEL_COMPETITOR_ANALYST=llama-3.1-8b-instant

# Max critic <-> strategist revision rounds
MAX_REVISIONS=1

# Concurrency for parallel pipelines
ANALYSIS_CONCURRENCY=2
COMPETITOR_CONCURRENCY=2

# --- Database ----------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bi_platform

# --- Redis (optional, only for BullMQ workers) ------------------
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Scraping (for competitor analysis) --------------------------
# ScrapingBee: used on Vercel (Playwright runs locally without this)
# Free tier: https://www.scrapingbee.com/ — 1k credits/mo
SCRAPINGBEE_API_KEY=

# --- App ---------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Auth --------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-random-secret

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Stripe -------------------------------------------------------
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_replace-me
STRIPE_WEBHOOK_SECRET=whsec_replace-me
STRIPE_GROWTH_PRICE_ID=price_replace-me
STRIPE_ENTERPRISE_PRICE_ID=price_replace-me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace-me

# --- Inngest (for Vercel background jobs) ------------------------
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=

# --- Cron schedules -----------------------------------------------
WEATHER_FETCH_CRON=0 6 * * *
COMPETITOR_SCRAPE_CRON=0 8 * * *
DAILY_ANALYSIS_CRON=0 9 * * *

# --- Test scripts -------------------------------------------------
TEST_BUSINESS_ID=test-biz-1
TEST_CITY=Tokyo
