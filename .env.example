# Groq API key. Get one at https://console.groq.com/keys
GROQ_API_KEY=replace-me

# Default model. Free tier picks:
#   llama-3.1-8b-instant       (fast, simple - default for all agents)
#   llama-3.3-70b-versatile    (slower, smarter)
#   mixtral-8x7b-32768
GROQ_MODEL=llama-3.1-8b-instant

# Per-request cap on tokens returned by any agent call.
GROQ_NUM_PREDICT=512

# Optional: override the model used for ALL agents in the pipeline.
# When set, individual MODEL_* vars below are ignored.
# GROQ_MODEL_OVERRIDE=

# Optional: per-agent model overrides (defaults to llama-3.1-8b-instant)
# MODEL_MENU_ANALYST=llama-3.1-8b-instant
# MODEL_WEATHER_ANALYST=llama-3.1-8b-instant
# MODEL_STRATEGIST=llama-3.3-70b-versatile
# MODEL_CRITIC=llama-3.3-70b-versatile
# MODEL_SYNTHESIZER=llama-3.1-8b-instant
# MODEL_COMPETITOR_PARSER=llama-3.1-8b-instant

# Maximum number of critic <-> strategist revision rounds.
MAX_REVISIONS=1

# Concurrency for the AI analysis worker (pipelines processed in parallel).
ANALYSIS_CONCURRENCY=2

# Concurrency for the competitor-scrape worker (URLs scraped in parallel).
# Be conservative - each worker launches a headless Chromium.
COMPETITOR_CONCURRENCY=2

# --- Database ----------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bi_platform

# --- Redis -------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Weather -----------------------------------------------------
# Open-Meteo is free, no API key needed.
WEATHER_API_URL=https://api.open-meteo.com/v1

# --- Menu source -------------------------------------------------
# Directory where JSON menu files live (one file per business: <businessId>.json)
MENU_JSON_DIR=

# --- App ---------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Auth ---------------------------------------------------------
# Auth.js secret - generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-random-secret

# Google OAuth (optional - for Google sign-in)
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Stripe --------------------------------------------------------
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_replace-me
STRIPE_WEBHOOK_SECRET=whsec_replace-me
STRIPE_GROWTH_PRICE_ID=price_replace-me
STRIPE_ENTERPRISE_PRICE_ID=price_replace-me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace-me

# --- Cron schedules ---------------------------------------------
WEATHER_FETCH_CRON=0 6 * * *
SALES_PULL_CRON=0 7 * * *
COMPETITOR_SCRAPE_CRON=0 8 * * *
DAILY_ANALYSIS_CRON=0 9 * * *

# --- Test script -------------------------------------------------
TEST_BUSINESS_ID=test-biz-1
TEST_CITY=Tokyo
